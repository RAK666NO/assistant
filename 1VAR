int historyIndex = -1;

// ============ Text to Speech ============
void Speak(const std::wstring& text) {
    if (pVoice) {
        pVoice->Speak(text.c_str(), SPF_DEFAULT, NULL);
    }
}

// ============ Media Control ============
void SendMediaKey(BYTE keyCode) {
    INPUT ip = {0};
    ip.type = INPUT_KEYBOARD;
    ip.ki.wVk = keyCode;
    
    SendInput(1, &ip, sizeof(INPUT));
    Sleep(50);
    ip.ki.dwFlags = KEYEVENTF_KEYUP;
    SendInput(1, &ip, sizeof(INPUT));
}

void MediaPlayPause() {
    SendMediaKey(VK_MEDIA_PLAY_PAUSE);
    Speak(L"Пауза");
}

void MediaNextTrack() {
    SendMediaKey(VK_MEDIA_NEXT_TRACK);
    Speak(L"Следующий трек");
}

void MediaPrevTrack() {
    SendMediaKey(VK_MEDIA_PREV_TRACK);
    Speak(L"Предыдущий трек");
}

void VolumeUp() {
    SendMediaKey(VK_VOLUME_UP);
    Speak(L"Громче");
}

void VolumeDown() {
    SendMediaKey(VK_VOLUME_DOWN);
    Speak(L"Тише");
}

void VolumeMute() {
    SendMediaKey(VK_VOLUME_MUTE);
    Speak(L"Звук выключен");
}

void OpenBrowser(const std::wstring& url) {
    ShellExecuteW(NULL, L"open", url.c_str(), NULL, NULL, SW_SHOWNORMAL);
    Speak(L"Открываю");
}

void OpenProgram(const std::wstring& program) {
    ShellExecuteW(NULL, L"open", program.c_str(), NULL, NULL, SW_SHOWNORMAL);
    Speak(L"Запускаю");
}

void LockComputer() {
    LockWorkStation();
    Speak(L"Компьютер заблокирован");
}

void ShowDesktop() {
    keybd_event(VK_LWIN, 0, 0, 0);
    keybd_event('D', 0, 0, 0);
    keybd_event('D', 0, KEYEVENTF_KEYUP, 0);
    keybd_event(VK_LWIN, 0, KEYEVENTF_KEYUP, 0);
    Speak(L"Рабочий стол");
}

void OpenTaskManager() {
    keybd_event(VK_LCONTROL, 0, 0, 0);
    keybd_event(VK_LSHIFT, 0, 0, 0);
    keybd_event(VK_ESCAPE, 0, 0, 0);
    keybd_event(VK_ESCAPE, 0, KEYEVENTF_KEYUP, 0);
    keybd_event(VK_LSHIFT, 0, KEYEVENTF_KEYUP, 0);
    keybd_event(VK_LCONTROL, 0, KEYEVENTF_KEYUP, 0);
    Speak(L"Диспетчер задач");
}

